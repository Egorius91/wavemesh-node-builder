+wm_native_fetch_public() {
+  local url="$1" output="$2" attempt
+  for attempt in $(seq 1 10); do
+    if curl -fsSk --max-time 10 -H 'Accept: text/plain' "$url" -o "$output"; then
+      return 0
+    fi
+    (( attempt < 10 )) && sleep 1
+  done
+  return 1
+}
