#!/usr/bin/env bash
set -Eeuo pipefail

WM_STATE_DIR="/etc/wavemesh-node"
WM_REPORT_TXT="/root/wavemesh-node-report.txt"
WM_REPORT_JSON="/root/wavemesh-node-report.json"
WM_SUB_DIR="/var/www/wavemesh-sub"
WM_LIB_DIR="${WAVEMESH_LIB_DIR:-/usr/local/lib/wavemesh}"
if [[ ! -d "$WM_LIB_DIR" ]]; then WM_LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts" && pwd)"; fi

fail(){ echo "✗ $*" >&2; exit 1; }
info(){ echo "ℹ $*"; }
ok(){ echo "✓ $*"; }

load_config(){
  [[ -f "$WM_STATE_DIR/config.env" ]] || fail "Missing $WM_STATE_DIR/config.env"
  source "$WM_STATE_DIR/config.env"
}

validate_subscription(){
  load_config
  local content public_content source_url
  source_url="https://${DOMAIN}${SUB_PATH}"
  content="$(cat "$WM_SUB_DIR/sub.txt" 2>/dev/null || true)"
  [[ -n "$content" ]] || fail "Subscription file is empty"
  [[ "$content" == *"vless://"* ]] || fail "No vless links found"
  grep -q "@${DOMAIN}:443" <<< "$content" || fail "Missing ${DOMAIN}:443"
  grep -q "type=xhttp" <<< "$content" || fail "Missing type=xhttp"
  grep -q "mode=stream-one" <<< "$content" || fail "Missing mode=stream-one"
  grep -q "security=tls" <<< "$content" || fail "Missing security=tls"
  grep -q "sni=${DOMAIN}" <<< "$content" || fail "Missing sni=${DOMAIN}"
  grep -q "host=${DOMAIN}" <<< "$content" || fail "Missing host=${DOMAIN}"
  for bad in 127.0.0.1 localhost "$PUBLIC_IP" "$XHTTP_LOCAL_PORT" "$PANEL_PORT"; do
    [[ -z "$bad" ]] && continue
    if grep -q "$bad" <<< "$content"; then fail "Subscription leaks forbidden value: $bad"; fi
  done
  public_content="$(curl -fsSk --max-time 10 "$source_url" 2>/dev/null || true)"
  [[ -n "$public_content" ]] || fail "Public subscription URL is not reachable: $source_url"
  [[ "$public_content" == "$content" ]] || fail "Public subscription content does not match generated file"
  ok "Subscription OK: $source_url"
}

case "${1:-}" in
  cascade)
    shift
    source "$WM_LIB_DIR/00_common.sh"
    source "$WM_LIB_DIR/lib/transaction.sh"
    source "$WM_LIB_DIR/lib/xui_api.sh"
    source "$WM_LIB_DIR/lib/inbound_adapter.sh"
    source "$WM_LIB_DIR/lib/xray_template.sh"
    source "$WM_LIB_DIR/lib/nginx_renderer.sh"
    source "$WM_LIB_DIR/lib/subscription_renderer.sh"
    WM_CASCADE_TOOL="$WM_LIB_DIR/lib/cascade.py"
    WM_AUTO_TOOL="$WM_LIB_DIR/lib/auto_route.py"
    WM_RUNTIME_TOOL="$WM_LIB_DIR/lib/runtime_state.py"
    source "$WM_LIB_DIR/commands/runtime.sh"
    source "$WM_LIB_DIR/commands/auto.sh"
    source "$WM_LIB_DIR/commands/cascade.sh"
    wm_cascade_command "$@"
    ;;
  route)
    shift
    source "$WM_LIB_DIR/00_common.sh"
    source "$WM_LIB_DIR/lib/transaction.sh"
    source "$WM_LIB_DIR/lib/xui_api.sh"
    source "$WM_LIB_DIR/lib/inbound_adapter.sh"
    source "$WM_LIB_DIR/lib/xray_template.sh"
    source "$WM_LIB_DIR/lib/nginx_renderer.sh"
    source "$WM_LIB_DIR/lib/subscription_renderer.sh"
    WM_RUNTIME_TOOL="$WM_LIB_DIR/lib/runtime_state.py"
    source "$WM_LIB_DIR/commands/runtime.sh"
    wm_route_command "$@"
    ;;
  reconcile)
    shift
    source "$WM_LIB_DIR/00_common.sh"
    source "$WM_LIB_DIR/lib/transaction.sh"
    source "$WM_LIB_DIR/lib/xui_api.sh"
    source "$WM_LIB_DIR/lib/inbound_adapter.sh"
    source "$WM_LIB_DIR/lib/xray_template.sh"
    source "$WM_LIB_DIR/lib/nginx_renderer.sh"
    source "$WM_LIB_DIR/lib/subscription_renderer.sh"
    source "$WM_LIB_DIR/lib/subscription_presentation.sh"
    WM_RUNTIME_TOOL="$WM_LIB_DIR/lib/runtime_state.py"
    source "$WM_LIB_DIR/commands/runtime.sh"
    wm_reconcile_command "$@"
    ;;
  subscription)
    shift
    source "$WM_LIB_DIR/00_common.sh"
    source "$WM_LIB_DIR/lib/transaction.sh"
    source "$WM_LIB_DIR/lib/nginx_renderer.sh"
    source "$WM_LIB_DIR/lib/subscription_renderer.sh"
    source "$WM_LIB_DIR/lib/subscription_presentation.sh"
    source "$WM_LIB_DIR/commands/subscription.sh"
    wm_subscription_command "$@"
    ;;
  exit)
    shift
    source "$WM_LIB_DIR/00_common.sh"
    source "$WM_LIB_DIR/lib/transaction.sh"
    source "$WM_LIB_DIR/lib/xui_api.sh"
    source "$WM_LIB_DIR/lib/inbound_adapter.sh"
    source "$WM_LIB_DIR/lib/nginx_renderer.sh"
    WM_EXIT_PEER_TOOL="$WM_LIB_DIR/lib/exit_peer.py"
    source "$WM_LIB_DIR/commands/exit_peer.sh"
    [[ "${1:-}" == "peer" ]] || wm_fail "Usage: wavemesh exit peer create|list|remove"
    shift; wm_exit_peer_command "$@"
    ;;
  transaction)
    shift
    source "$WM_LIB_DIR/00_common.sh"
    source "$WM_LIB_DIR/lib/xui_api.sh"
    source "$WM_LIB_DIR/lib/xray_template.sh"
    source "$WM_LIB_DIR/lib/nginx_renderer.sh"
    source "$WM_LIB_DIR/lib/subscription_renderer.sh"
    source "$WM_LIB_DIR/lib/transaction.sh"
    wm_transaction_command "$@"
    ;;
  show-report)
    [[ -f "$WM_REPORT_TXT" ]] && cat "$WM_REPORT_TXT" || fail "Report not found"
    ;;
  diagnostics)
    load_config
    case "${NODE_ROLE:-standalone}" in
      entry) "$0" cascade health ;;
      exit)
        systemctl is-active --quiet nginx && ok "nginx active" || fail "nginx inactive"
        systemctl is-active --quiet x-ui && ok "3X-UI active" || fail "3X-UI inactive"
        [[ -f "/etc/letsencrypt/live/${DOMAIN}/fullchain.pem" ]] && ok "SSL certificate exists" || fail "SSL missing"
        [[ -n "${PANEL_TOKEN:-}" ]] && ok "3X-UI bearer API token present" || fail "3X-UI bearer API token missing"
        curl -fsS --max-time 5 "http://127.0.0.1:${PANEL_PORT}${PANEL_PATH}" >/dev/null 2>&1 && ok "3X-UI panel reachable on loopback" || fail "3X-UI panel is not reachable on loopback"
        ok "Exit diagnostics OK; client subscription is not applicable"
        ;;
      standalone)
        systemctl is-active --quiet nginx && ok "nginx active" || fail "nginx inactive"
        [[ -f "/etc/letsencrypt/live/${DOMAIN}/fullchain.pem" ]] && ok "SSL certificate exists" || fail "SSL missing"
        validate_subscription
        ;;
      *) fail "Unsupported node role: ${NODE_ROLE}" ;;
    esac
    ;;
  validate-subscription) validate_subscription ;;
  repair)
    case "${2:-}" in
      --nginx) nginx -t && systemctl reload nginx && ok "nginx reloaded" ;;
      --ssl) load_config; certbot renew --dry-run ;;
      --subscriptions) validate_subscription ;;
      *) fail "Usage: wavemesh repair --nginx|--ssl|--subscriptions" ;;
    esac
    ;;
  *)
    cat <<'EOF'
Usage:
  wavemesh show-report
  wavemesh diagnostics
  wavemesh validate-subscription
  wavemesh exit peer create --entry-id ID [--entry-ip IP] --display-name TEXT --output FILE
  wavemesh exit peer list
  wavemesh exit peer remove --entry-id ID
  wavemesh cascade add-exit --manifest FILE [--display-name TEXT] [--sort-order N] [--dry-run]
  wavemesh cascade auto create [--id ID] [--display-name TEXT] [--exit-id ID ...] [--sort-order N] [--dry-run]
  wavemesh cascade auto status [--json]
  wavemesh cascade list
  wavemesh cascade status [--json]
  wavemesh cascade health [--exit-id ID] [--json]
  wavemesh cascade verify-e2e [--json]
  wavemesh cascade remove-exit --exit-id ID [--force]
  wavemesh route list [--json]
  wavemesh route enable --route-id ID
  wavemesh route disable --route-id ID
  wavemesh route remove --route-id ID
  wavemesh reconcile --dry-run|--apply
  wavemesh subscription rebuild
  wavemesh subscription validate
  wavemesh transaction list [--json]
  wavemesh transaction recover --id ID|--latest
  wavemesh repair --nginx
  wavemesh repair --ssl
  wavemesh repair --subscriptions
EOF
    ;;
esac
