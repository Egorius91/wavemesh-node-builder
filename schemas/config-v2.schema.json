{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wavemesh.local/schemas/config-v2.schema.json",
  "type": "object",
  "required": ["schema_version", "node", "server", "network", "panel", "clients", "exits", "routes", "relay_peers"],
  "properties": {
    "schema_version": {"const": 2},
    "node": {"type": "object", "required": ["id", "role", "country", "city"], "properties": {"id": {"$ref": "#/$defs/id"}, "role": {"enum": ["standalone", "entry", "exit"]}, "country": {"anyOf": [{"const": ""}, {"pattern": "^[A-Z]{2}$"}]}, "city": {"type": "string", "maxLength": 128}}},
    "server": {"type": "object", "required": ["domain"], "properties": {"domain": {"type": "string", "minLength": 1}}},
    "network": {"type": "object", "required": ["public_port", "subscription"]},
    "panel": {"type": "object", "required": ["listen_port", "path", "username", "password", "api_auth"]},
    "clients": {"type": "array"}, "exits": {"type": "array"}, "routes": {"type": "array"}, "relay_peers": {"type": "array"}, "migrations": {"type": "array"}
  },
  "$defs": {"id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,47}$"}, "path": {"type": "string", "minLength": 12, "maxLength": 128, "pattern": "^/(?!.*(?:\\.\\.|%2[fF]|\\s)).*/$"}}
}
